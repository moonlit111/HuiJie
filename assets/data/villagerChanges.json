        //Pierre — 添加关于慧杰想在店门口摆摊的对话
        {
            "LogName": "Pierre dialogue about huijie",
            "Action": "EditData",
            "Target": "Characters/Dialogue/Pierre",
            "Entries": {
                "huijieSaloonConfession": "那个卖桃子的家伙又想在我店门口摆摊了！他居然说我的商品'不够高端'，只有他精心培育的桃子才配得上'有品味的顾客'。他自己卖过期桃子的人！我尊重竞争，但至少给我留点空间吧？$2"
            }
        },

        //Leah — 添加关于慧杰的对话
        {
            "LogName": "Leah dialogue about huijie",
            "Action": "EditData",
            "Target": "Characters/Dialogue/Leah",
            "Entries": {
                "huijieSaloonConfession": "慧杰昨天试图向我解释鱼类神经系统。他讲得激动的时候脖子伸得老长，像只加拉帕戈斯象龟。虽然他的理论很有趣，但我不确定海豚是不是真的像他说的那样...$2"
            }
        },

        //Emily — 添加关于慧杰的对话
        {
            "LogName": "Emily dialogue about huijie",
            "Action": "EditData",
            "Target": "Characters/Dialogue/Emily",
            "Entries": {
                "huijieSaloonConfession": "慧杰的气场很独特...充满了桃子和俯卧撑的能量。说实话，他脖子长长的，让我想起纪录片里的加拉帕戈斯象龟。我帮他做了一件桃子色的围巾！$1"
            }
        },

        //Sam — 添加关于慧杰的对话
        {
            "LogName": "Sam dialogue about huijie",
            "Action": "EditData",
            "Target": "Characters/Dialogue/Sam",
            "Entries": {
                "huijieSaloonConfession": "那个慧杰叔叔居然挑战我做俯卧撑比赛...我做了三十个就放弃了。他做了一百个还在继续，伸着长脖子做俯卧撑的样子，就像一只加拉帕戈斯象龟。但又像象龟一样倔强。$2"
            }
        },

        //Abigail — 添加关于慧杰的对话
        {
            "LogName": "Abigail dialogue about huijie",
            "Action": "EditData",
            "Target": "Characters/Dialogue/Abigail",
            "Entries": {
                "huijieSaloonConfession": "那个卖桃子的家伙说他研究过鱼类？我给他看了一张河豚的照片——那可是我最喜欢的鱼——他盯了半天，然后问我是不是给他看了一只海豚。$2#$b#...我本来还想和他聊聊鱼的，但现在我只想远离他的桃子。$1"
            }
        }
    ]
